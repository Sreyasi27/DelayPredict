# OpenWeatherMap API Key (get free key at https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Set to "mock" to skip real API calls (useful for dev without keys)
WEATHER_MODE=mock

# Firebase Admin SDK - path to your service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Maps API Key (used server-side for Directions API if needed)
GOOGLE_MAPS_API_KEY=AIzaSyBqkyuYoJWjB11wvFtyKIrbPJEbcEJZJ-s

# Gemini API Key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
